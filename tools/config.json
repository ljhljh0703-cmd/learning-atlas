      "🧠 AI · LLM 연구",
      "🎨 디자인 · 프론트엔드",
      "🧰 도구 · 방법론"
    ],
    "rules": [
      {"group": "🧰 도구 · 방법론", "match": ["toss", "앱인토스", "앱빌더"]},
      {"group": "🧰 도구 · 방법론", "match": ["prompt-pattern", "prompt pattern"]},
      {"group": "🧠 AI · LLM 연구", "match": ["mech-interp", "interpretability", "activation-steering", "persona-vector", "transformerlens"]},
